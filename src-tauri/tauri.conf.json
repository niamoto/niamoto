{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Niamoto",
  "version": "0.11.0",
  "identifier": "com.niamoto.desktop",
  "build": {
    "frontendDist": "../src/niamoto/gui/ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Niamoto Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:*; frame-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'",
      "freezePrototype": true
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "deb", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/niamoto"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNjMwRDhDNEQ0QTE1QkIKUldTN0ZVcE5qQTFqN3hGTWJ4ZG5DaUxmM3NieEE3VVc3Z1VxWjR2TUt0dWZxN0NMQm4xc3JiMzAK",
      "endpoints": [
        "https://github.com/niamoto/niamoto/releases/latest/download/latest.json"
      ]
    }
  }
}
