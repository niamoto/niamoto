{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Niamoto",
  "version": "0.12.2",
  "identifier": "com.niamoto.desktop",
  "build": {
    "frontendDist": "../src/niamoto/gui/ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Niamoto Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 30
        },
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "deb", "msi"],
    "resources": {
      "resources/sidecar/": "sidecar/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNjMwRDhDNEQ0QTE1QkIKUldTN0ZVcE5qQTFqN3hGTWJ4ZG5DaUxmM3NieEE3VVc3Z1VxWjR2TUt0dWZxN0NMQm4xc3JiMzAK",
      "endpoints": [
        "https://github.com/niamoto/niamoto/releases/latest/download/latest.json"
      ]
    }
  }
}
