{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Niamoto",
  "version": "0.16.2",
  "identifier": "com.niamoto.desktop",
  "build": {
    "frontendDist": "../src/niamoto/gui/ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Niamoto",
        "width": 1280,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#f5f6f7"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "base-uri": "'self'",
        "form-action": "'self'",
        "object-src": "'none'",
        "frame-ancestors": "'none'",
        "frame-src": "'self'",
        "connect-src": "'self' http://127.0.0.1:* http://localhost:* https:",
        "img-src": "'self' data: blob: https:",
        "media-src": "'self' data: blob:",
        "font-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-inline'",
        "worker-src": "'self' blob:"
      },
      "freezePrototype": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "deb", "msi"],
    "resources": {
      "resources/sidecar/": "sidecar/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNjMwRDhDNEQ0QTE1QkIKUldTN0ZVcE5qQTFqN3hGTWJ4ZG5DaUxmM3NieEE3VVc3Z1VxWjR2TUt0dWZxN0NMQm4xc3JiMzAK",
      "endpoints": [
        "https://github.com/niamoto/niamoto/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
